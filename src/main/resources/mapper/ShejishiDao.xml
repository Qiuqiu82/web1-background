<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.ShejishiDao">

    <resultMap type="com.entity.ShejishiEntity" id="shejishiMap">
        <result property="shejishizhanghao" column="shejishizhanghao"/>
        <result property="mima" column="mima"/>
        <result property="shejishixingming" column="shejishixingming"/>
        <result property="touxiang" column="touxiang"/>
        <result property="lianxifangshi" column="lianxifangshi"/>
        <result property="zhuanchang" column="zhuanchang"/>
        <result property="jianjie" column="jianjie"/>
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.ShejishiVO">
        SELECT * FROM shejishi shejishi
        <where>1=1 ${ew.sqlSegment}</where>
    </select>

    <select id="selectVO" resultType="com.entity.vo.ShejishiVO">
        SELECT shejishi.* FROM shejishi shejishi
        <where>1=1 ${ew.sqlSegment}</where>
    </select>

    <select id="selectListView" resultType="com.entity.view.ShejishiView">
        SELECT shejishi.* FROM shejishi shejishi
        <where>1=1 ${ew.sqlSegment}</where>
    </select>

    <select id="selectView" resultType="com.entity.view.ShejishiView">
        SELECT * FROM shejishi shejishi
        <where>1=1 ${ew.sqlSegment}</where>
    </select>

</mapper>
